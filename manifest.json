{
  "manifest_version": 3,
  "name": "记事本",
  "version": "1.0.0",
  "description": "一个简洁的 Chrome 记事本插件，支持编辑和保存文本",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "记事本"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"]
}
